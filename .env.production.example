# =============================================================================
# Process Metrics Platform - PRODUCTION Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in your actual values.
#
# SECURITY NOTES:
#   - Never commit .env.production to git!
#   - Use strong, unique passwords for production
#   - Consider using a secrets manager for sensitive values
#
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# For Digital Ocean Managed Databases, use connection pooler URL
POSTGRES_DB=process_metrics
POSTGRES_USER=metrics_app
POSTGRES_PASSWORD=<GENERATE_STRONG_PASSWORD_HERE>

# Full database URL (for managed database, use this format):
# DATABASE_URL=postgresql://doadmin:<PASSWORD>@<HOST>:25060/process_metrics?sslmode=require

# -----------------------------------------------------------------------------
# Jira Integration
# -----------------------------------------------------------------------------
# These are used as fallback if config/projects.yaml is not configured
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_USER_EMAIL=admin@your-company.com
JIRA_API_TOKEN=<YOUR_JIRA_API_TOKEN>

# For multiple Jira instances, add more tokens:
# JIRA_SECONDARY_TOKEN=<SECOND_INSTANCE_TOKEN>

# Legacy: Comma-separated project keys (prefer config/projects.yaml)
# JIRA_PROJECTS=PROJ1,PROJ2

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ENVIRONMENT=production
LOG_LEVEL=WARNING

# Secret key for JWT/sessions (generate with: openssl rand -hex 32)
SECRET_KEY=<GENERATE_WITH_openssl_rand_-hex_32>

# -----------------------------------------------------------------------------
# Docker/Ports Configuration
# -----------------------------------------------------------------------------
# Port mapping (change if conflicts with other services)
APP_PORT=8000
DAGSTER_PORT=3000
METABASE_PORT=3001

# Docker registry for pre-built images (optional)
# DOCKER_REGISTRY=ghcr.io/your-org
# IMAGE_TAG=v1.0.0

# -----------------------------------------------------------------------------
# Metabase Settings (optional)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
# METABASE_SECRET_KEY=<ENCRYPTION_KEY>
# METABASE_EMBEDDING_TOKEN=<IF_USING_EMBEDDING>

# -----------------------------------------------------------------------------
# Dagster Settings
# -----------------------------------------------------------------------------
DAGSTER_HOME=/opt/dagster/dagster_home

# Config file path (default: /opt/dagster/app/config/projects.yaml)
# PLATFORM_CONFIG_PATH=/opt/dagster/app/config/projects.yaml
