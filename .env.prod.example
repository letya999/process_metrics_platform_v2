# =============================================================================
# Production Environment - DigitalOcean Droplet
# =============================================================================
# Copy this file to .env.prod and fill in your actual values.
# NEVER commit .env.prod to git!

# Database
POSTGRES_DB=process_metrics_v2
POSTGRES_USER=pmp_user
POSTGRES_PASSWORD=<GENERATE: openssl rand -base64 32>

# Application
ENVIRONMENT=production
LOG_LEVEL=WARNING
SECRET_KEY=<GENERATE: openssl rand -hex 32>
ADMIN_AUTH_SECRET=<GENERATE: openssl rand -hex 32>

# Jira
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_USER_EMAIL=you@your-company.com
JIRA_API_TOKEN=<YOUR_JIRA_API_TOKEN>

# Metabase
MB_ADMIN_EMAIL=admin@your-company.com
MB_ADMIN_PASSWORD=<GENERATE: openssl rand -base64 16>
METABASE_SECRET_KEY=<GENERATE: openssl rand -hex 32>

# Ports
APP_PORT=8000
DAGSTER_PORT=3000
METABASE_PORT=3001

# Dagster
DAGSTER_HOME=/opt/dagster/dagster_home

# Caddy / Reverse Proxy
# SERVER_IP - public IP of the server (used in Caddyfile for nip.io subdomains)
# DAGSTER_BASIC_AUTH_HASH - generate with: caddy hash-password --plaintext YOUR_PASSWORD
SERVER_IP=<YOUR_SERVER_PUBLIC_IP>
DAGSTER_BASIC_AUTH_HASH=<caddy hash-password --plaintext YOUR_PASSWORD>
