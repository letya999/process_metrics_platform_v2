# =============================================================================
# Caddy Configuration for Process Metrics Platform
# =============================================================================
# Required env vars (from .env.prod):
#   MB_DOMAIN
#   DAGSTER_DOMAIN
#   API_DOMAIN
#   ADMIN_DOMAIN
# =============================================================================

{$MB_DOMAIN} {
    reverse_proxy metabase:3000
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

{$DAGSTER_DOMAIN} {
    reverse_proxy dagster-webserver:3000
    header {
        X-Content-Type-Options "nosniff"
    }
}

{$API_DOMAIN} {
    reverse_proxy app:8000
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
    }
}

{$ADMIN_DOMAIN} {
    reverse_proxy admin-ui:8501
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
    }
}
