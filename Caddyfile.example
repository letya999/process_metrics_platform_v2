# Required environment variables:
#   SERVER_IP            - Your server's public IP address
#   DAGSTER_BASIC_AUTH_HASH - Generate with: caddy hash-password --plaintext YOUR_PASSWORD

# =============================================================================
# Caddy Configuration for Process Metrics Platform
# Using nip.io for secure HTTPS access via IP: ${SERVER_IP}
# =============================================================================

# Metabase (BI Dashboard)
http://metrics.${SERVER_IP}.nip.io {
    reverse_proxy metabase:3000

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

# Dagster UI (ETL monitoring)
http://dagster.${SERVER_IP}.nip.io {
    # Basic Auth for security
    # Replace the hash below with your own (generated via 'caddy hash-password')
    basicauth * {
        admin {$DAGSTER_BASIC_AUTH_HASH}
    }

    reverse_proxy dagster:3000

    header {
        X-Content-Type-Options "nosniff"
    }
}

# FastAPI (Admin Panel / API)
http://api.${SERVER_IP}.nip.io {
    reverse_proxy app:8000

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
    }
}

# Streamlit Admin Studio
http://admin.${SERVER_IP}.nip.io {
    reverse_proxy admin-ui:8501

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
    }
}
