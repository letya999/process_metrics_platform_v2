# =============================================================================
# Caddy Configuration for Process Metrics Platform
# Automatic HTTPS via Let's Encrypt for ktts.space subdomains
# Required env vars: MB_DOMAIN, DAGSTER_DOMAIN, API_DOMAIN, ADMIN_DOMAIN
# =============================================================================

# Metabase (BI Dashboard)
{$MB_DOMAIN} {
    reverse_proxy metabase:3000

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

# Dagster UI (ETL monitoring)
{$DAGSTER_DOMAIN} {
    reverse_proxy dagster-webserver:3000

    header {
        X-Content-Type-Options "nosniff"
    }
}

# FastAPI (Admin Panel / API)
{$API_DOMAIN} {
    reverse_proxy app:8000

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
    }
}

# Streamlit Admin Studio
{$ADMIN_DOMAIN} {
    reverse_proxy admin-ui:8501

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
    }
}
