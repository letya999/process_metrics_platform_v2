@asset(
    group_name="jira",
    deps=[raw_jira_issues],      # Explicit dependency
    compute_kind="sql"
)
def clean_jira_issues(context: AssetExecutionContext, db: DatabaseResource) -> None:
    """Transform raw issues to clean layer."""
