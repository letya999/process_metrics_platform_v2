## 4. Integration Tests

### What to Test
- API endpoints
- Database operations
- Dagster asset execution
- External service mocking

### Example

```python
# tests/integration/test_api_integrations.py
import pytest
from httpx import AsyncClient
from app.main import app

@pytest.fixture
async def client():
    async with AsyncClient(app=app, base_url="http://test") as ac:
        yield ac

@pytest.mark.asyncio
async def test_create_integration(client, db_session):
    response = await client.post(
        "/api/v1/integrations",
        json={
            "type": "jira",
            "config": {
                "base_url": "https://test.atlassian.net",
                "projects": ["PROJ"]
            }
        }
    )

    assert response.status_code == 201
    assert response.json()["data"]["type"] == "jira"

@pytest.mark.asyncio
async def test_list_integrations(client, db_session, sample_integration):
    response = await client.get("/api/v1/integrations")

    assert response.status_code == 200
    assert len(response.json()["data"]) >= 1
```

