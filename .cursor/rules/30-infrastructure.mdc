## 5. Makefile

```makefile
.PHONY: dev test lint format migrate

# Development
dev:
	docker-compose up -d

down:
	docker-compose down

logs:
	docker-compose logs -f

# Testing
test:
	pytest tests/ -v

test-cov:
	pytest tests/ --cov=app --cov=pipelines --cov-report=html

# Linting
lint:
	ruff check app/ pipelines/
	black --check app/ pipelines/

format:
	ruff check --fix app/ pipelines/
	black app/ pipelines/

# Database
migrate:
	alembic upgrade head

migrate-create:
	alembic revision --autogenerate -m "$(MSG)"

migrate-down:
	alembic downgrade -1

# Dependencies
deps-export:
	pdm export --prod --without-hashes -o requirements.txt

# Docker
docker-build:
	docker-compose build

docker-up:
	docker-compose up -d

docker-down:
	docker-compose down -v
```

