## 4. Dependency Management

### Python (PDM)

```bash
# Install dependencies
pdm install

# Add new dependency
pdm add <package>

# Export for Docker
pdm export --prod --without-hashes -o requirements.txt

# Update lock file
pdm lock
```

### Files

| File | Purpose |
|------|---------|
| `pyproject.toml` | Dependency declaration |
| `pdm.lock` | Locked versions |
| `requirements.txt` | For Docker (auto-generated) |

### pyproject.toml Template

```toml
[project]
name = "process-metrics"
version = "0.1.0"
requires-python = ">=3.11"
dependencies = [
    "dagster>=1.6.0",
    "dagster-webserver>=1.6.0",
    "dagster-dlt>=0.23.0",
    "dlt[postgres]>=1.0.0",
    "fastapi>=0.110.0",
    "uvicorn>=0.27.0",
    "sqlalchemy>=2.0.0",
    "alembic>=1.14.0",
    "asyncpg>=0.29.0",
    "pydantic>=2.0.0",
    "python-dotenv>=1.0.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0.0",
    "pytest-asyncio>=0.23.0",
    "pytest-cov>=4.0.0",
    "ruff>=0.3.0",
    "black>=24.0.0",
]

[tool.pdm]
distribution = false

[tool.black]
line-length = 88
target-version = ["py311"]

[tool.ruff]
line-length = 88
select = ["E", "F", "W", "I"]

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
```

