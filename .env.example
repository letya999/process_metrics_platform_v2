# =============================================================================
# Process Metrics Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_DB=process_metrics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Full database URL (used by app and alembic)
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/process_metrics

# -----------------------------------------------------------------------------
# Dagster Configuration
# -----------------------------------------------------------------------------
DAGSTER_HOME=/opt/dagster/dagster_home
DAGSTER_POSTGRES_HOST=postgres
DAGSTER_POSTGRES_USER=postgres
DAGSTER_POSTGRES_PASSWORD=your_secure_password_here
DAGSTER_POSTGRES_DB=process_metrics

# -----------------------------------------------------------------------------
# Jira Integration
# -----------------------------------------------------------------------------
# Your Jira Cloud instance URL (e.g., https://company.atlassian.net)
JIRA_BASE_URL=https://your-company.atlassian.net

# Email associated with your Jira account
JIRA_USER_EMAIL=your-email@company.com

# API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# -----------------------------------------------------------------------------
# Integration URL safety policy
# -----------------------------------------------------------------------------
# Allowed URL schemes for instance_url values (comma-separated)
INTEGRATION_ALLOWED_URL_SCHEMES=https
# Optional host allowlist globs (empty means any host)
INTEGRATION_ALLOWED_HOST_PATTERNS=
# Allow private IP literals (RFC1918). Useful for internal networks.
INTEGRATION_ALLOW_PRIVATE_IPS=true
# localhost is blocked by default
INTEGRATION_ALLOW_LOCALHOST=false

# -----------------------------------------------------------------------------
# GitLab Integration (optional, for future use)
# -----------------------------------------------------------------------------
# GITLAB_URL=https://gitlab.com
# GITLAB_TOKEN=your_gitlab_token_here

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Environment: development, staging, production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Secret key for JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here
# Optional dedicated signing key for admin API bearer tokens (if missing, SECRET_KEY is used)
ADMIN_AUTH_SECRET=your_admin_auth_secret_here
# Admin access token lifetime in minutes (5..1440)
ADMIN_AUTH_TTL_MINUTES=120
# Global revoke timestamp (unix seconds or ISO8601), empty = disabled
ADMIN_TOKENS_INVALID_BEFORE=

# Caddy reverse proxy
SERVER_IP=YOUR_SERVER_IP_HERE
DAGSTER_BASIC_AUTH_HASH=<run: caddy hash-password --plaintext YOUR_PASSWORD>

# -----------------------------------------------------------------------------
# Metabase Configuration (for auto-setup)
# -----------------------------------------------------------------------------
# Admin email and password for automatic setup
MB_ADMIN_EMAIL=admin@example.com
MB_ADMIN_PASSWORD=<CHANGE_ME_GENERATE_STRONG_PASSWORD>
